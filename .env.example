# Copie para .env e ajuste se necessário. O docker-compose já tem
# defaults (estes mesmos valores), então rodar sem .env funciona.

# --- App ---
NODE_ENV=development
APP_PORT=3333

# --- PostgreSQL ---
POSTGRES_USER=cellshop
POSTGRES_PASSWORD=cellshop
POSTGRES_DB=cellshop
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_USER=cellshop
RABBITMQ_PASSWORD=cellshop
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=cellshop
DATABASE_PASSWORD=cellshop
DATABASE_NAME=cellshop
DATABASE_SSL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB_NUMBER=0
